<Window
    x:Class="BootSequence.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowSpacing="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Choose Windows" Style="{ThemeResource TitleTextBlockStyle}" />

        <InfoBar x:Name="StatusBar" Grid.Row="1" IsOpen="False" IsClosable="False" />

        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing" IsActive="True" Width="32" Height="32" />
            <ListView x:Name="BootList"
                      Visibility="Collapsed"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      HorizontalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
