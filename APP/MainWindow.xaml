<Window
    x:Class="BootSequence.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="MainPage"
              Padding="28,24,28,20"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Choose Windows" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Select the next startup"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.72" />
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4">
                <ComboBox x:Name="BootMethodBox"
                          Header="Method"
                          SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="BCDEdit" />
                            <TextBlock Text="(Recommended)" Opacity="0.55" />
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem Content="Raw" />
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="WMI Windows API" />
                            <TextBlock Text="(Can be slower)" Opacity="0.55" />
                        </StackPanel>
                    </ComboBoxItem>
                </ComboBox>
                <TextBlock x:Name="LastTimingText"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.72"
                           Visibility="Collapsed" />
            </StackPanel>

            <InfoBar x:Name="StatusBar"
                     Grid.Row="2"
                     IsOpen="False"
                     IsClosable="False" />

            <Grid Grid.Row="3">
                <ProgressRing x:Name="LoadingRing" IsActive="True" Width="32" Height="32" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="BootList"
                                Spacing="8"
                                Visibility="Collapsed" />
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid x:Name="AboutPage"
              Padding="28,24,28,20"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="About" Style="{ThemeResource TitleTextBlockStyle}" />
                <Button HorizontalAlignment="Right"
                        Width="36"
                        Height="36"
                        Padding="0"
                        Click="BackButton_Click"
                        AutomationProperties.Name="Back"
                        ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,24,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Developer"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.65" />
                        <TextBlock Text="IBRAHIM"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Website"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.65" />
                        <HyperlinkButton Content="ibrhub.net"
                                         NavigateUri="https://ibrhub.net"
                                         Padding="0" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Discord"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.65" />
                        <HyperlinkButton Content="dis.ibrhub.net"
                                         NavigateUri="https://dis.ibrhub.net"
                                         Padding="0" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="GitHub"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.65" />
                        <HyperlinkButton Content="github.com/ibrhub/BootSequence"
                                         NavigateUri="https://github.com/ibrhub/BootSequence"
                                         Padding="0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,8,20,10">
            <Button x:Name="AboutButton"
                    Content="About"
                    HorizontalAlignment="Left"
                    Click="AboutButton_Click" />
        </Border>
    </Grid>
</Window>
